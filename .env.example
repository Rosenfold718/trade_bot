# =============================================
# Vercel Environment Variables — COPY THESE
# =============================================
#
# 1. TURSO_DATABASE_URL — ваша ссылка Turso (libsql://...)
# 2. TURSO_AUTH_TOKEN   — ваш токен Turso
# 3. NEXTAUTH_SECRET    — секрет для сессий (можно оставить этот)
# 4. NEXTAUTH_URL       — https://ваш-домен.vercel.app
# 5. ADMIN_SETUP_KEY    — ключ для создания админа
#
# DATABASE_URL больше НЕ НУЖЕН для работы!
# =============================================

TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

NEXTAUTH_SECRET=trade-terminal-super-secret-key-2024-x32chars
NEXTAUTH_URL=https://your-app.vercel.app

ADMIN_SETUP_KEY=trade-bot-admin-2024