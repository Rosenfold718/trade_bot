# Prisma schema validation (same value as TURSO_DATABASE_URL)
DATABASE_URL=libsql://your-db-name-your-org.turso.io

# NextAuth.js
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
NEXTAUTH_URL=https://your-app.vercel.app

# Admin setup key (used once to create admin account)
ADMIN_SETUP_KEY=trade-bot-admin-2024

# Turso Cloud Database (ALL data — auth tables + trading data)
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
